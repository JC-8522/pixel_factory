{
  "name": "local-codex-office",
  "version": "0.1.0",
  "description": "A local desktop office for visualizing and coordinating Codex agents.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint .",
    "package": "electron-vite build && electron-builder --dir",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pixi.js": "^8.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sql.js": "^1.13.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "build": {
    "appId": "com.localcodex.office",
    "productName": "Local Codex Office",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
